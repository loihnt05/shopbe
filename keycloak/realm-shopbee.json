{
  "realm": "ShopBee",
  "enabled": true,

  "displayName": "ShopBee",

  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,

  "sslRequired": "none",

  "identityProviders": [
    {
      "alias": "google",
      "providerId": "google",
      "enabled": false,
      "updateProfileFirstLoginMode": "on",
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "config": {
        "clientId": "${GOOGLE_CLIENT_ID}",
        "clientSecret": "${GOOGLE_CLIENT_SECRET}",
        "defaultScope": "openid profile email",
        "prompt": "consent",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "github",
      "providerId": "github",
      "enabled": false,
      "updateProfileFirstLoginMode": "on",
      "trustEmail": true,
      "storeToken": false,
      "addReadTokenRoleOnCreate": false,
      "config": {
        "clientId": "${GITHUB_CLIENT_ID}",
        "clientSecret": "${GITHUB_CLIENT_SECRET}",
        "defaultScope": "read:user user:email",
        "syncMode": "IMPORT"
      }
    }
  ],

  "identityProviderMappers": [
    {
      "name": "google-email",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "claim": "email",
        "user.attribute": "email",
        "syncMode": "INHERIT"
      }
    },
    {
      "name": "google-firstName",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "claim": "given_name",
        "user.attribute": "firstName",
        "syncMode": "INHERIT"
      }
    },
    {
      "name": "google-lastName",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "claim": "family_name",
        "user.attribute": "lastName",
        "syncMode": "INHERIT"
      }
    },
    {
      "name": "github-email",
      "identityProviderAlias": "github",
      "identityProviderMapper": "github-user-attribute-mapper",
      "config": {
        "jsonField": "email",
        "user.attribute": "email",
        "syncMode": "INHERIT"
      }
    },
    {
      "name": "github-login",
      "identityProviderAlias": "github",
      "identityProviderMapper": "github-user-attribute-mapper",
      "config": {
        "jsonField": "login",
        "user.attribute": "github_login",
        "syncMode": "INHERIT"
      }
    }
  ],

  "clients": [
    {
      "clientId": "shopbe-swagger",
      "name": "Shopbe Swagger UI",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": false,

      "redirectUris": [
        "http://localhost:*/swagger/oauth2-redirect.html",
        "http://localhost:5072/swagger/oauth2-redirect.html",
        "https://localhost:*/swagger/oauth2-redirect.html",
        "http://127.0.0.1:*/swagger/oauth2-redirect.html",
        "https://127.0.0.1:*/swagger/oauth2-redirect.html",
        "http://shopbe-web:*/swagger/oauth2-redirect.html",
        "https://shopbe-web:*/swagger/oauth2-redirect.html"
      ],
      "webOrigins": [
        "+"
      ],

      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },

      "defaultClientScopes": [
        "web-origins",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "shopfend",
      "name": "Shopfend (Next.js)",
      "enabled": true,

      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "frontchannelLogout": false,

      "redirectUris": [
        "http://localhost:3000/api/auth/callback/keycloak",
        "http://127.0.0.1:3000/api/auth/callback/keycloak",
        "http://localhost:3000",
        "http://127.0.0.1:3000",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000"
      ],

      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },

      "defaultClientScopes": [
        "web-origins",
        "roles",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "shopbe-api",
      "name": "Shopbe API",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "standardFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect"
    }
  ]
}

